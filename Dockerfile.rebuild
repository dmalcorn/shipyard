# Dockerfile.rebuild — Shipyard pipeline runner
# Runs the full rebuild pipeline in an isolated Linux environment
# with all tools pre-installed. No preflight surprises.

FROM python:3.13-slim

# System tools: git, make, curl, jq, plus node/npm for frontend projects
RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
        make \
        curl \
        jq \
        ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Go toolchain for Go projects
RUN curl -fsSL https://go.dev/dl/go1.24.1.linux-amd64.tar.gz | tar -C /usr/local -xz
ENV PATH="/usr/local/go/bin:/root/go/bin:${PATH}"
RUN go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest

# Claude CLI (installed globally via npm)
RUN npm install -g @anthropic-ai/claude-code

# Python dev tools (linting, type checking, testing)
RUN pip install --no-cache-dir ruff mypy pytest

# Playwright for browser-based acceptance tests (frontend projects)
RUN npm install -g playwright && npx playwright install --with-deps chromium

# Shipyard factory code
WORKDIR /app/shipyard
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY src/ src/

# Workspace for the target project (mounted or copied at runtime)
RUN mkdir -p /app/workspace

# Git identity for commits made by agents inside the container.
# Defaults here; overridden at runtime by GIT_AUTHOR_NAME / GIT_AUTHOR_EMAIL
# env vars passed from .env via docker-compose.
ENV GIT_AUTHOR_NAME="Shipyard Pipeline"
ENV GIT_AUTHOR_EMAIL="shipyard@pipeline.local"
ENV GIT_COMMITTER_NAME="Shipyard Pipeline"
ENV GIT_COMMITTER_EMAIL="shipyard@pipeline.local"

# Prevent Claude CLI "config file not found" warnings
RUN echo '{}' > /root/.claude.json

WORKDIR /app/shipyard

ENTRYPOINT ["python", "-m", "src.main", "--rebuild", "/app/workspace"]
