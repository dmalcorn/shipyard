# Anthropic API key — required for Claude model access
ANTHROPIC_API_KEY=your-key-here

# LangSmith tracing — set to "true" to enable trace collection
LANGCHAIN_TRACING_V2=true

# LangSmith API key — required when tracing is enabled
LANGCHAIN_API_KEY=your-langsmith-key-here

# LangSmith project name — traces are grouped under this project
LANGCHAIN_PROJECT=shipyard

# Web relay — streams pipeline output to the public Railway dashboard
# Set both to enable; leave blank to disable relay
SHIPYARD_RELAY_URL=https://shipyard-production-29ae.up.railway.app
SHIPYARD_RELAY_KEY=your-relay-key-here

# Git identity for commits made by the pipeline (used in Docker and local runs)
GIT_AUTHOR_NAME=Shipyard Pipeline
GIT_AUTHOR_EMAIL=shipyard@pipeline.local
